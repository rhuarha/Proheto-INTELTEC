{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "drizzle-kit push --config ./drizzle.config.ts",
    "push-force": "drizzle-kit push --force --config ./drizzle.config.ts",
    "seed:clientes": "tsx --env-file=../../.env ./src/seeds/seed-clientes.ts",
    "seed:municipios": "tsx --env-file=../../.env ./src/seeds/seed-municipios.ts",
    "migrate:clientes-municipio": "tsx --env-file=../../.env ./src/seeds/migrate-clientes-municipio.ts",
    "cleanup:clientes-teste": "tsx --env-file=../../.env ./src/seeds/cleanup-clientes-teste.ts"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "catalog:"
  }
}
